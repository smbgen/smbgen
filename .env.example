# ==============================================
# APPLICATION SETTINGS
# ==============================================
# APP_NAME: Application name used in browser titles and notifications
APP_NAME=YourAppName
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance & Performance
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
APP_VERSION=1.0.0

# ==============================================
# LOGGING
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================
# DATABASE
# ==============================================
DB_CONNECTION=sqlite
DB_DATABASE=./database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

# ==============================================
# SESSION & CACHE
# ==============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
# CACHE_PREFIX=

# ==============================================
# QUEUE & BROADCASTING
# ==============================================
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

# ==============================================
# FILESYSTEM
# ==============================================
FILESYSTEM_DISK=local
# Use 's3' for Laravel Cloud/Vapor or production with cloud storage
FILESYSTEM_DRIVER=local

# ==============================================
# REDIS
# ==============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==============================================
# MEMCACHED
# ==============================================
MEMCACHED_HOST=127.0.0.1

# ==============================================
# EMAIL CONFIGURATION
# ==============================================
# PRODUCTION: Replace with real SMTP credentials (Mailgun, Resend, SES, Postmark, etc.)
# Mailtrap below is for local dev/testing only — emails do NOT reach real inboxes.
# Example for Resend: MAIL_MAILER=smtp, HOST=smtp.resend.com, PORT=465, USERNAME=resend, PASSWORD=re_xxxxx
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=admin@example.com

# Resend API Configuration (alternative to SMTP)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx


# ==============================================
# AWS SERVICES (for S3 storage)
# ==============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==============================================
# THIRD-PARTY INTEGRATIONS
# ==============================================

# Google OAuth (for user login)
# REQUIRED for login/register with Google to work. Get credentials from Google Cloud Console.
# Note: You must register ALL redirect URIs in Google Cloud Console → APIs & Services → Credentials
# Local: http://localhost:8000/auth/google/callback
# Production: https://yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Google Calendar (for calendar integration - MUST be /admin/calendar/callback)
# Local: http://localhost:8000/admin/calendar/callback
# Production: https://yourdomain.com/admin/calendar/callback
# IMPORTANT: Register BOTH URIs in Google Cloud Console > APIs & Services > Credentials
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/admin/calendar/callback

# Google Cloud Storage (DEPRECATED - use Laravel Cloud bucket instead)
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_STORAGE_BUCKET=
# GOOGLE_CLOUD_KEY_FILE=
# Note: Google Cloud Storage support is deprecated in favor of Laravel Cloud's native bucket

# QuickBooks Integration
QUICKBOOKS_CLIENT_ID=id-for-quickbooks
QUICKBOOKS_CLIENT_SECRET=secret-for-quickbooks
QUICKBOOKS_REDIRECT_URI="${APP_URL}/admin/quickbooks/callback"
QUICKBOOKS_ENVIRONMENT=sandbox

# Stripe
STRIPE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Alternative Stripe naming (used by business config)
# STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# AI Content Generation (Anthropic Claude)
# Toggle the AI content features and configure the Claude provider.
# API key can be set here or securely via the Admin > AI Settings page (DB takes precedence).
AI_CONTENT_GENERATION_ENABLED=false
AI_PROVIDER=anthropic
# Claude API key: required when AI is enabled.
ANTHROPIC_API_KEY=
# Model and generation defaults
ANTHROPIC_MODEL=claude-opus-4-1
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7
# Rate limiting and logging
AI_RATE_LIMIT_ENABLED=true
AI_MAX_REQUESTS_PER_HOUR=60
AI_MAX_REQUESTS_PER_DAY=200
AI_LOGGING_ENABLED=true

# Phone System (Bland AI / Twilio)
BLAND_API_KEY=
BLAND_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==============================================
# FRONTEND BUILD
# ==============================================
# Enable/disable public frontend module (routes/views) by default.
# Set true to enable frontend pages like /, /services, /solutions.
FRONTEND_ENABLED=false
VITE_APP_NAME="${APP_NAME}"

# ==============================================
# FEATURE FLAGS
# ==============================================
FEATURE_APPOINTMENTS=true
FEATURE_EMAIL_COMPOSER=true
FEATURE_CMS=true
FEATURE_BLOG=true
FEATURE_FILE_MANAGEMENT=true
FEATURE_MESSAGES=true
FEATURE_INSPECTION_REPORTS=false
FEATURE_BILLING=true
FEATURE_PHONE_SYSTEM=true

# ==============================================
# BUSINESS CONFIGURATION
# ==============================================

# Business Identity
# COMPANY_NAME is the primary business name used throughout the app (login, admin panel, etc.)
COMPANY_NAME=YourCompanyName
# BUSINESS_NAME is optional - only set if you want a different name for public-facing CMS/navbar
# If not set, it will use COMPANY_NAME
# BUSINESS_NAME=Your Public Brand Name
BUSINESS_TAGLINE="Client Management & AI Tools"
BUSINESS_DESCRIPTION="Professional client management platform with AI-powered tools"
BUSINESS_TYPE=general

# Theme Mode (light|dark)
# Controls the global color scheme for the admin panel
# See app/docs/architecture/THEME_SYSTEM.md for details
THEME_MODE=dark

# Contact Information (used in emails and forms)
# ⚠️ CRITICAL: BUSINESS_EMAIL must be a VALID mailbox on your SMTP server!
# This address receives deployment notifications and system emails.
# If this email doesn't exist on your mail server, deployment notifications will fail with "550 No Such User Here".
BUSINESS_EMAIL=support@example.com
BUSINESS_PHONE=


# Booking Settings
BOOKING_REQUIRE_PROPERTY_ADDRESS=false
BOOKING_SHOW_PROPERTY_ADDRESS=true
BOOKING_REQUIRE_PHONE=false
BOOKING_SHOW_PHONE=true
BOOKING_CREATE_LEAD=true

# Billing Settings
BILLING_HOURLY_RATE_CENTS=20000

# Deployment
DEPLOYMENT_INSTANCE=production

# ==============================================
# ADDITIONAL SERVICES
# ==============================================
GOOGLE_ANALYTICS_ID=
GOOGLE_MAPS_API_KEY=

