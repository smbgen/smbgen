Timestamp: {{ now()->format('Y-m-d H:i:s') }}</textarea>
                    </div>

                    <div class="flex gap-3">
                        <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-2 rounded-lg transition-colors">
                            <i class="fas fa-paper-plane mr-2"></i>Send Test Email
                        </button>
                        <button type="button" onclick="document.getElementById('emailDebugModal').classList.add('hidden')" 
                                class="bg-gray-700 hover:bg-gray-600 text-white font-medium px-4 py-2 rounded-lg transition-colors">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>

            <!-- Quick Tips -->
            <div class="mt-4 bg-yellow-900/30 border border-yellow-500/50 rounded-lg p-4">
                <h4 class="text-gray-200 font-semibold mb-2">Tips:</h4>
                <ul class="text-sm text-yellow-200 space-y-1">
                    <li>• Check spam folder if email doesn't arrive</li>
                    <li>• Verify SMTP credentials in .env file</li>
                    <li>• Ensure firewall allows SMTP port (465/587)</li>
                    <li>• Check Laravel logs for detailed errors</li>
                </ul>
            </div>
        </div>
    </div>
</div>
@endif

@push('scripts')
<script>
    // Auto-refresh leads table
    function fetchLeads() {
        fetch("{{ route('leads.partial') }}")
            .then(response => response.text())
            .then(html => {
                // Update the leads table content
                console.log('Leads updated');
            })
            .catch(error => console.error('Error fetching leads:', error));
    }

    // Refresh leads every 15 seconds
    setInterval(fetchLeads, 15000);
    
    // Toggle client form visibility
    function toggleClientForm() {
        const content = document.getElementById('clientFormContent');
        const chevron = document.getElementById('clientFormChevron');
        
        if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            chevron.style.transform = 'rotate(180deg)';
        } else {
            content.classList.add('hidden');
            chevron.style.transform = 'rotate(0deg)';
        }
    }
    
    // Booking row expansion with chevron rotation
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('[id^="booking-details-"]').forEach(function(detailsRow) {
            const bookingId = detailsRow.id.replace('booking-details-', '');
            const chevron = document.getElementById('chevron-' + bookingId);
            
            if (chevron) {
                const observer = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.attributeName === 'class') {
                            if (detailsRow.classList.contains('hidden')) {
                                chevron.style.transform = 'rotate(0deg)';
                            } else {
                                chevron.style.transform = 'rotate(90deg)';
                            }
                        }
                    });
                });
                
                observer.observe(detailsRow, { attributes: true });
            }
        });

        // Quick client creation form handling
        const firstNameInput = document.getElementById('first_name');
        const lastNameInput = document.getElementById('last_name');
        const fullNameInput = document.getElementById('full_name');
        const clientForm = document.getElementById('quickClientForm');

        function updateFullName() {
            const firstName = firstNameInput.value.trim();
            const lastName = lastNameInput.value.trim();
            fullNameInput.value = (firstName + ' ' + lastName).trim();
        }

        firstNameInput.addEventListener('input', updateFullName);
        lastNameInput.addEventListener('input', updateFullName);

        // Handle form submission for meeting creation
        clientForm.addEventListener('submit', function(e) {
            updateFullName(); // Ensure name is updated before submission
            
            const action = e.submitter.value;
            if (action === 'meeting') {
                // Store meeting intent in session/localStorage
                localStorage.setItem('startMeetingAfterClientCreate', 'true');
                localStorage.setItem('meetingClientEmail', document.getElementById('client_email').value);
            }
        });
    });
</script>
@endpush
@endsection
